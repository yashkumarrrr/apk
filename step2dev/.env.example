# ── DATABASE (required) ──────────────────────────────────────────────────────
# Get free PostgreSQL at: https://neon.tech  OR  https://supabase.com
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/step2dev?schema=public"

# ── APP ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── JWT (required) ────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-to-a-random-64-char-string-minimum-32-chars-required"

# ── EMAIL ─────────────────────────────────────────────────────────────────────
# Option A – Resend (free 3000/month): https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxx"
EMAIL_FROM="AccIQ <noreply@yourdomain.com>"

# Option B – SMTP (Gmail, etc.)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="you@gmail.com"
# SMTP_PASS="your-16-char-app-password"

# NOTE: In development, if neither is set, emails print to the terminal console.

# Part 6 — Auto CI/CD
# Secret for manually triggering the cron endpoint (optional)
CRON_SECRET="your-cron-secret"

# Part 7 — AI Automation (Anthropic)
ANTHROPIC_API_KEY="sk-ant-..."
